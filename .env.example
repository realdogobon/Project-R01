# Port to run the application (defaults to 3000)
PORT=3000

# Environment mode (production / development)
NODE_ENV=development

# Gemini API Keys (comma-separated or single)
GEMINI_API_KEY=
GEMINI_API_KEYS=

# Groq API Keys (comma-separated or single)
GROQ_API_KEY=
GROQ_API_KEYS=

# OpenAI API Keys (comma-separated or single)
OPENAI_API_KEY=
OPENAI_API_KEYS=
